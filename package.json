{
  "name": "writeai",
  "version": "1.0.0",
  "description": "Always-on AI writing assistant for better English",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "echo 'Static site - no build needed'",
    "build:app": "electron-builder --mac",
    "build:all": "electron-builder --mac --win"
  },
  "keywords": ["writing", "ai", "assistant", "english"],
  "author": "medoismail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/medoismail/writeai"
  },
  "build": {
    "appId": "design.medoismail.writeai",
    "productName": "WriteAI",
    "asar": true,
    "compression": "maximum",
    "mac": {
      "artifactName": "${productName}-Mac-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "minimumSystemVersion": "12.0"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "!node_modules/**/{test,tests,__tests__,spec}/**",
      "!node_modules/**/*.{md,ts,map}",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/.github/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^25.1.8"
  }
}
